# Core service
HOST=127.0.0.1
PORT=8787

# Security
API_KEY=change_me_to_a_strong_random_key
RATE_LIMIT_PER_MINUTE=20

# Redis / queue
REDIS_URL=redis://127.0.0.1:6379
QUEUE_NAME=seedance-video-jobs
JOB_TTL_SECONDS=86400

# Upstream
SEEDANCE_PAGE_URL=https://veoaifree.com/seedance-2-0-video-generator-free/
SEEDANCE_AJAX_URL=https://veoaifree.com/wp-admin/admin-ajax.php

# Worker behavior
INITIAL_POLL_DELAY_MS=85000
POLL_INTERVAL_MS=20000
MAX_POLL_ATTEMPTS=36
REQUEST_TIMEOUT_MS=30000
